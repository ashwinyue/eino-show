# eino-show 环境配置示例
# 使用说明: 复制此文件为 .env 并修改相应配置

# ========== 数据库配置 ==========
# PostgreSQL 端口
DB_PORT=5432
# PostgreSQL 用户名
DB_USER=einoshow
# PostgreSQL 密码
DB_PASSWORD=einoshow1234
# PostgreSQL 数据库名
DB_NAME=einoshow

# ========== Redis 配置 ==========
# Redis 端口
REDIS_PORT=6379
# Redis 密码 (留空表示无密码)
REDIS_PASSWORD=

# ========== 应用配置 ==========
# 服务模式: gin, grpc, grpc-gateway
SERVER_MODE=grpc-gateway
# JWT 签名密钥
JWT_KEY=Rtg8BPKNEf2mB4mgvKONGPZZQSaJWNLijxR42qRgq0iBb5
# Token 过期时间
EXPIRATION=2h
# 是否启用内存数据库 (开发环境可设为 true)
ENABLE_MEMORY_STORE=false

# ========== HTTP 服务器配置 ==========
# HTTP 服务器监听地址
HTTP_ADDR=:5555

# ========== gRPC 服务器配置 ==========
# gRPC 服务器监听地址
GRPC_ADDR=:6666

# ========== TLS 配置 ==========
# 是否启用 HTTPS
USE_TLS=false
# TLS 证书路径 (启用 HTTPS 时需要)
TLS_CERT=/opt/einoshow/etc/cert/server.crt
# TLS 密钥路径 (启用 HTTPS 时需要)
TLS_KEY=/opt/einoshow/etc/cert/server.key

# ========== LLM 模型配置 ==========
# LLM API Base URL (例如: https://api.openai.com/v1)
LLM_BASE_URL=
# LLM API Key
LLM_API_KEY=
# LLM 模型名称
LLM_MODEL_NAME=gpt-4o-mini

# ========== Embedding 模型配置 ==========
# Embedding API Base URL
EMBEDDING_BASE_URL=
# Embedding API Key
EMBEDDING_API_KEY=
# Embedding 模型名称
EMBEDDING_MODEL_NAME=text-embedding-3-small
# Embedding 向量维度
EMBEDDING_DIMENSION=1536

# ========== Qwen DashScope 配置 ==========
# DashScope API Key (阿里云通义千问)
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
# Qwen 模型名称 (如: qwen-plus, qwen-turbo, qwen-max)
QWEN_MODEL_NAME=qwen-plus

# ========== Coze-Loop 追踪配置 ==========
# Coze-Loop 控制台: https://loop.coze.cn
# Workspace ID (从控制台设置页获取)
COZELOOP_WORKSPACE_ID=
# API Token (从控制台设置页获取)
COZELOOP_API_TOKEN=

# ========== 日志配置 ==========
# 日志级别: debug, info, warn, error
LOG_LEVEL=debug
# 日志格式: console, json
LOG_FORMAT=json
